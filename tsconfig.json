{
  "compilerOptions": {
    "baseUrl": ".",
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "esnext",
    "skipLibCheck": true,
    "strict": false,
    "types": ["bun-types"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
